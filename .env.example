# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: never expose to the client. Used for inviting/removing staff.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: bootstrap / owner login — must match a user you allow; syncs to Supabase on sign-in (needs service role key).
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Optional: allow in-memory admin mutations in production (guide/building data)
# ALLOW_IN_MEMORY_ADMIN_WRITES=true
